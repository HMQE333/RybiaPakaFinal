modules = ["nodejs-20", "web", "postgresql-16"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
PORT = "5000"
NEXT_PUBLIC_SITE_URL = "https://6f8050f6-1fc0-4c4d-8e0e-30be532bb2bf-00-2pyxv8nnrqvhs.spock.replit.dev"
BETTER_AUTH_URL = "https://6f8050f6-1fc0-4c4d-8e0e-30be532bb2bf-00-2pyxv8nnrqvhs.spock.replit.dev"
NEXTAUTH_URL = "https://6f8050f6-1fc0-4c4d-8e0e-30be532bb2bf-00-2pyxv8nnrqvhs.spock.replit.dev"
PRISMA_RESTORE = "0"

[userenv.development]
PRISMA_MIGRATE = "1"
PRISMA_GENERATE = "1"

[userenv.production]
PRISMA_MIGRATE = "0"
PRISMA_GENERATE = "0"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "cloudrun"
run = ["sh", "-c", "node ./scripts/run-prod.js"]
build = ["sh", "-c", "bash scripts/deploy-build.sh"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000
