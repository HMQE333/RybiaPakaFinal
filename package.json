{
  "name": "rybiapaka",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.26.1",
  "scripts": {
    "pretty": "pnpm exec prettier . --write",
    "dev": "next dev -p 5000 -H 0.0.0.0",
    "build": "next build",
    "start": "node ./scripts/run-prod.js",
    "start:raw": "next start",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "node ./scripts/guard-dev.js prisma migrate dev",
    "prisma:seed": "node ./scripts/guard-dev.js prisma db seed",
    "prisma:seed:prod": "pnpm exec tsx prisma/seed.prod.ts",
    "restore-db": "node ./scripts/guard-dev.js node ./scripts/restore-db.js",
    "test-db": "node ./scripts/test-prisma-conn.js",
    "dev:local": "node ./scripts/run-dev-local.js",
    "check:logo": "node ./scripts/check-logo.js",
    "check:uploads": "node ./scripts/check-uploads.js"
  },
  "prisma": {
    "seed": "pnpm exec tsx prisma/seed.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp"
    ]
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "@types/leaflet": "^1.9.21",
    "bcryptjs": "latest",
    "better-auth": "1.4.6",
    "clsx": "^2.1.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.552.0",
    "maplibre-gl": "^5.21.0",
    "next": "16.0.10",
    "nodemailer": "^7.0.10",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-leaflet": "^5.0.0",
    "react-map-gl": "^8.1.0",
    "sharp": "^0.33.5",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "baseline-browser-mapping": "^2.9.11",
    "prettier": "3.6.2",
    "prisma": "5.22.0",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
