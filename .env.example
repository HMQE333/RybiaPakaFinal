# Copy this file to .env and fill values for production.

# ─── Database ──────────────────────────────────────────────────────────────────
# Replit's built-in PostgreSQL sets all of these automatically.
# To switch to Supabase (or any other PostgreSQL provider) simply replace
# DATABASE_URL with your Supabase connection string — nothing else needs to change.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
PGHOST=HOST
PGPORT=5432
PGUSER=USER
PGPASSWORD=PASSWORD
PGDATABASE=DATABASE

# ─── Base URLs ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://rybiapaka.pl
BETTER_AUTH_URL=https://rybiapaka.pl
NEXTAUTH_URL=https://rybiapaka.pl

# ─── Secrets (use long random values; keep them in sync) ───────────────────────
NEXTAUTH_SECRET=CHANGE_ME_TO_LONG_RANDOM
AUTH_SECRET=CHANGE_ME_TO_LONG_RANDOM
BETTER_AUTH_SECRET=CHANGE_ME_TO_LONG_RANDOM

# ─── Prisma / data service ─────────────────────────────────────────────────────
PRISMA_PROJECT_ROOT=/var/www/rybiapaka
PRISMA_MIGRATE=1
PRISMA_GENERATE=1
PRISMA_RESTORE=0

# Data service (internal RPC bridge between Next.js and apps/data)
DATA_BASE_URL=http://localhost:4000
DATA_SERVICE_TOKEN=CHANGE_ME_TO_LONG_RANDOM
DATA_DB_PROVIDER=postgresql

# ─── Uploads ───────────────────────────────────────────────────────────────────
UPLOADS_DIR=/var/www/rybiapaka/uploads

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ─── SMTP (optional) ───────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="RybiaPaka.pl <no-reply@rybiapaka.pl>"

# ─── OAuth providers (optional) ────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
